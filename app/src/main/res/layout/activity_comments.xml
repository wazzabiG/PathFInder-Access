<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="#33FFFFFF"
            android:tint="#FFFFFF"
            android:contentDescription="Go back"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCommentsLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvCommentsDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#DAFFDE"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Section label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COMMENTS"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:letterSpacing="0.10"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp"/>

    <!-- Comments list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvComments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvNoComments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No comments yet. Be the first!"
        android:textSize="14sp"
        android:textColor="@color/colorOnSurfaceVariant"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"/>

    <!-- Comment input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorSurface"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <EditText
            android:id="@+id/etComment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Add a comment..."
            android:textSize="14sp"
            android:background="@color/colorBackground"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:maxLines="3"
            android:inputType="textMultiLine"/>

        <ImageButton
            android:id="@+id/btnPostComment"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@color/colorPrimary"
            android:tint="#FFFFFF"
            android:layout_marginStart="8dp"
            android:contentDescription="Post comment"/>
    </LinearLayout>

</LinearLayout>