<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Back/header area -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnSurface"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the PathFinder Access community!"
            android:textSize="14sp"
            android:textColor="@color/colorOnSurfaceVariant"
            android:layout_marginBottom="36dp" />

        <!-- Section: Personal Information -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERSONAL INFORMATION"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:letterSpacing="0.10"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etFirstName"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="First Name *" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etLastName"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="Last Name *" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etEmail"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="Email Address *" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etPhone"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="Phone Number (Optional)" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="phone"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="28dp" />

        <!-- Section: Accessibility Profile -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCESSIBILITY PROFILE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:letterSpacing="0.10"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Helps us show you more relevant alerts."
            android:textSize="13sp"
            android:textColor="@color/colorOnSurfaceVariant"
            android:layout_marginBottom="12dp" />

        <Spinner android:id="@+id/spinnerMobilityType"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginBottom="28dp" />

        <!-- Section: Emergency Contact -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY CONTACT (OPTIONAL)"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:letterSpacing="0.10"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etEmergencyName"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="Contact Name" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etEmergencyPhone"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="Contact Phone Number" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="phone"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="28dp" />

        <!-- Section: Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CREATE PASSWORD"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:letterSpacing="0.10"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etPassword"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="Password (min. 6 characters) *" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etRepeatPassword"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="Repeat Password *" android:textSize="16sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="32dp" />

        <Button android:id="@+id/buttonRegisterSubmit"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Create Account"
            android:textSize="17sp" android:textStyle="bold"
            android:backgroundTint="@color/colorPrimary" android:textColor="#FFFFFF" />

        <TextView android:id="@+id/tvGoToLogin"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Already have an account? Sign In"
            android:textColor="@color/colorSecondary" android:textSize="15sp"
            android:textStyle="bold"
            android:padding="16dp" android:layout_gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
